#!/usr/bin/env bash
# real-estate setup — register skills with Claude Code
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

SKILLS=(
  lot-analysis
  budget-plan
  architect-brief
  plan-review
  permit-tracker
  spec-review
  bid-leveling
  builder-due-diligence
  contract-review
  schedule-review
  inspection-prep
  change-order-review
  draw-review
  site-visit
  punch-list
  warranty-tracker
  learn-trade
  cost-estimate
  code-lookup
  gc-license-path
  debrief
)

mkdir -p "$SKILLS_DIR"

echo "Registering real-estate skills with Claude Code..."

for skill in "${SKILLS[@]}"; do
  target="$SKILLS_DIR/$skill"
  if [ -L "$target" ]; then
    rm "$target"
  elif [ -d "$target" ]; then
    echo "  Warning: $target exists and is not a symlink — skipping"
    continue
  fi
  ln -s "$REPO_DIR/$skill" "$target"
  echo "  /$skill"
done

echo ""
echo "Done. Skills registered:"
for skill in "${SKILLS[@]}"; do
  echo "  /$skill"
done
echo ""
echo "Start with: /lot-analysis or /budget-plan"
